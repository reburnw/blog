---
type Props = {
  title?: string;
  description?: string;
  lang?: string;
};

const {
  title = 'Ricardo Wang',
  description = "我的技术分享 | Ricardo's personal blog",
  lang = 'en',
} = Astro.props;

const pageTitle = title === 'Ricardo Wang' ? `${title} | ${description}` : `${title} | Ricardo Wang`;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <link rel="alternate" type="application/rss+xml" title="Ricardo Wang" href="/feed.xml" />
    <title>{pageTitle}</title>
    <style is:global>
      :root {
        color-scheme: light;
        --bg: #f8f7f2;
        --paper: #fffdf8;
        --text: #242424;
        --muted: #68655e;
        --line: #ded9cd;
        --accent: #176b5b;
        --accent-2: #a14d2a;
        --code: #ebe5d8;
        font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        line-height: 1.65;
      }

      a {
        color: var(--accent);
        text-decoration-thickness: 0.08em;
        text-underline-offset: 0.18em;
      }

      img {
        max-width: 100%;
        height: auto;
      }

      .site-header,
      .site-footer,
      main {
        width: min(760px, calc(100% - 32px));
        margin-inline: auto;
      }

      .site-header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 20px;
        padding: 32px 0 24px;
        border-bottom: 1px solid var(--line);
      }

      .brand {
        color: var(--text);
        font-size: 1.2rem;
        font-weight: 700;
        text-decoration: none;
      }

      nav {
        display: flex;
        gap: 16px;
        font-size: 0.95rem;
      }

      main {
        padding: 36px 0 48px;
      }

      h1,
      h2,
      h3 {
        line-height: 1.25;
      }

      h1 {
        margin: 0 0 12px;
        font-size: clamp(2rem, 7vw, 3.25rem);
        letter-spacing: 0;
      }

      h2 {
        margin-top: 2rem;
      }

      .lede {
        color: var(--muted);
        font-size: 1.1rem;
        margin: 0 0 32px;
      }

      .post-list {
        display: grid;
        gap: 22px;
        padding: 0;
        margin: 32px 0 0;
        list-style: none;
      }

      .post-list li {
        border-top: 1px solid var(--line);
        padding-top: 22px;
      }

      .post-list a {
        color: var(--text);
        font-size: 1.15rem;
        font-weight: 650;
      }

      .meta {
        color: var(--muted);
        font-size: 0.92rem;
        margin: 6px 0 0;
      }

      article {
        background: var(--paper);
        border: 1px solid var(--line);
        border-radius: 8px;
        padding: clamp(20px, 5vw, 40px);
      }

      article > :first-child {
        margin-top: 0;
      }

      table {
        width: 100%;
        border-collapse: collapse;
        display: block;
        overflow-x: auto;
      }

      th,
      td {
        border: 1px solid var(--line);
        padding: 8px 10px;
      }

      code {
        background: var(--code);
        border-radius: 4px;
        padding: 0.12em 0.25em;
      }

      .site-footer {
        border-top: 1px solid var(--line);
        color: var(--muted);
        padding: 24px 0 40px;
        font-size: 0.92rem;
      }

      @media (max-width: 560px) {
        .site-header {
          align-items: flex-start;
          flex-direction: column;
        }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">Ricardo Wang</a>
      <nav aria-label="Main navigation">
        <a href="/">Blog</a>
        <a href="/about/">About</a>
        <a href="/nas/">NAS</a>
        <a href="https://grafana.ricardo.wang">Grafana</a>
        <a href="/feed.xml">RSS</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      Ricardo Wang. 我的技术分享.
    </footer>
  </body>
</html>
